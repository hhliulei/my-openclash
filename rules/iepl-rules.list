# =================================================================
# Clash 专用规则集 - IEPL 专线规则
# 用途: 将对 IP 质量要求极高的流量导向 IEPL 专线节点
# 作者: Clash 配置优化助手
# =================================================================
# 主要应用场景:
# 1. 苹果生态: Apple ID 登录、iCloud 服务、App Store 内购
# 2. 支付服务: PayPal, Stripe, Square, Adyen
# 3. 高价值账户: OpenAI (ChatGPT Plus) 升级、Anthropic (Claude Pro) 升级
# 4. 云服务提供商部分 API (需要干净 IP 的)
# =================================================================
# ---------------------【1. 苹果生态 - Apple ID & Services】---------------------
# Apple 的服务器在检测到异常 IP（如数据中心 IP、代理 IP）时，会触发安全验证。
# 使用 IEPL 专线，可以大大降低被锁账号的风险。
DOMAIN-SUFFIX,apple.com
DOMAIN-SUFFIX,icloud.com
DOMAIN-SUFFIX,icloud-content.com
DOMAIN-SUFFIX,icloud.com.cn
DOMAIN-SUFFIX,apple.com.cn
DOMAIN-SUFFIX,me.com
DOMAIN-SUFFIX,mac.com
DOMAIN-SUFFIX,aaplimg.com
DOMAIN-SUFFIX,itunes.apple.com
DOMAIN-SUFFIX,buy.itunes.apple.com
DOMAIN-SUFFIX,apps.itunes.apple.com
DOMAIN-SUFFIX,appstore.com
DOMAIN-SUFFIX,app-store.com
DOMAIN-SUFFIX,testflight.apple.com
DOMAIN-SUFFIX,developer.apple.com
DOMAIN-KEYWORD,apple
# ---------------------【2. 支付服务 - Financial & Payment】---------------------
# PayPal 和 Stripe 等支付网关对代理 IP 和异常 IP 非常敏感，极易风控或限制交易。
DOMAIN-SUFFIX,paypal.com
DOMAIN-SUFFIX,paypal.com.cn
DOMAIN-SUFFIX,paypal-content.com
DOMAIN-SUFFIX,paypal objects.com
DOMAIN-SUFFIX,payapi.com
DOMAIN-SUFFIX,payments-amazon.com
DOMAIN-SUFFIX,stripe.com
DOMAIN-SUFFIX,stripe.net
DOMAIN-SUFFIX,rcm.amazon.com
DOMAIN-SUFFIX,pay.amazon.com
DOMAIN-SQUARE,stripe.com # square.com 的支付相关域名
DOMAIN-SUFFIX,sqpay.com
DOMAIN-SUFFIX,adyen.com
DOMAIN-SUFFIX,adyenpayments.com
DOMAIN-SUFFIX,adyen.eu
DOMAIN-KEYWORD,paypal
DOMAIN-KEYWORD,stripe
DOMAIN-KEYWORD,adyen
# ---------------------【3. AI 服务账户管理 - AI Account Management】---------------------
# 用于升级 ChatGPT Plus, Claude Pro, Gemini Advanced 等服务。
# 使用干净的 IP 进行支付或绑定，可以避免支付失败或账户被临时限制。
DOMAIN-SUFFIX,openai.com
DOMAIN-SUFFIX,ai.com
DOMAIN-SUFFIX,stripe.com # OpenAI 和 Anthropic 都使用 Stripe 支付
DOMAIN-SUFFIX,anthropic.com
DOMAIN-SUFFIX,console.anthropic.com
DOMAIN-SUFFIX,buy.stripe.com
DOMAIN-SUFFIX,chat.openai.com
DOMAIN-SUFFIX,claude.ai
DOMAIN-KEYWORD,chatgpt
DOMAIN-KEYWORD,claude
DOMAIN-KEYWORD,perplexity
# ---------------------【4. 云服务提供商 - Cloud Services】---------------------
# 部分云服务商（如 Vercel, Netlify, DigitalOcean）的注册、支付或 API 调用
# 可能会要求来自干净或固定 IP 地址的请求。IEPL 专线非常适合。
DOMAIN-SUFFIX,vercel.com
DOMAIN-SUFFIX,netlify.com
DOMAIN-SUFFIX,netlify.app
DOMAIN-SUFFIX,digitalocean.com
DOMAIN-SUFFIX,digitaloceanspaces.com
DOMAIN-SUFFIX,dogado.eu
DOMAIN-KEYWORD,vercel
DOMAIN-KEYWORD,netlify
DOMAIN-KEYWORD,digitalocean
# ---------------------【5. 其他需要纯净 IP 的服务】---------------------
# 一些登录或验证服务，使用干净的 IP 可以获得更流畅的体验。
DOMAIN-SUFFIX,x.com
DOMAIN-SUFFIX,twidere.app
DOMAIN-SUFFIX,twidere雪山飞狐版.app
DOMAIN-KEYWORD,twidere